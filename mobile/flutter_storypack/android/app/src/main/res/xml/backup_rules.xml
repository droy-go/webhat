<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Include shared preferences -->
    <include domain="sharedpref" path="." />
    
    <!-- Include databases -->
    <include domain="database" path="." />
    
    <!-- Exclude cache -->
    <exclude domain="cache" path="." />
    <exclude domain="external" path="cache" />
</full-backup-content>
